# =============================================================
# Virtual environment
# =============================================================
qiskit-env/
venv/
.venv/
env/

# =============================================================
# Python
# =============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
MANIFEST

# =============================================================
# Jupyter
# =============================================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/
profile_default/
ipython_config.py

# =============================================================
# Test and coverage
# =============================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover

# =============================================================
# Results and generated data (runtime outputs, not committed)
# =============================================================
results/figures/*
results/reports/*
data/raw/*
data/processed/*
!results/figures/.gitkeep
!results/reports/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

# =============================================================
# macOS
# =============================================================
.DS_Store
.AppleDouble
.LSOverride
._*

# =============================================================
# IDEs
# =============================================================
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace

# =============================================================
